{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@dashboard/*": ["src/*"],
      "@alphred/agents": ["../../packages/agents/src/index.ts"],
      "@alphred/core": ["../../packages/core/src/index.ts"],
      "@alphred/db": ["../../packages/db/src/index.ts"],
      "@alphred/git": ["../../packages/git/src/index.ts"],
      "@alphred/shared": ["../../packages/shared/src/index.ts"]
    },
    "types": ["node", "vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "app/**/*.test.ts",
    "app/**/*.test.tsx",
    "scripts/**/*.test.ts",
    "../../test/setup.ts"
  ],
  "exclude": ["node_modules"]
}
